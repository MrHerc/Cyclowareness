# Cyclowareness backend configuration
# Copy to .env and adjust. Never commit real secrets.

# --- Core ---
SECRET_KEY=change-me-to-a-long-random-string
DATABASE_URL=sqlite:///./cyclowareness.db
# Production: DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/cyclowareness

# --- AI (Anthropic Claude) ---
# Leave empty to use the built-in deterministic MockAIProvider (demo mode).
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-5

# --- Sandbox analyzer: mock | real ---
SANDBOX_ANALYZER=mock
# RealAnalyzer backend config (used only when SANDBOX_ANALYZER=real)
REAL_ANALYZER_BACKEND=virustotal
REAL_ANALYZER_API_KEY=
REAL_ANALYZER_URL=

# --- Task queue: inprocess | celery ---
TASK_RUNNER=inprocess
REDIS_URL=redis://localhost:6379/0

# --- Loop pacing (seconds; makes the loop visibly "turn" in the UI) ---
STAGE_DELAY_ANALYZE=5
STAGE_DELAY_CONVERT=6
STAGE_DELAY_TARGET=3

# --- Behaviour ---
AUTO_APPROVE_TRAINING=false
ACCESS_TOKEN_EXPIRE_MINUTES=720
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
